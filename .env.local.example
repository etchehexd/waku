# --- AniList ---
# The public AniList GraphQL API needs no key for read access.
NEXT_PUBLIC_ANILIST_ENDPOINT=https://graphql.anilist.co

# --- Supabase (optional — Waku runs fully on local storage without it) ---
# Provide these to enable cloud sync of your library, ratings & rankings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
